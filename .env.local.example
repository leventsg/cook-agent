# 必需：从 https://platform.deepseek.com/ 获取你的 API Key
DEEPSEEK_API_KEY=你的_API_Key

# 可选：DeepSeek API 基础地址（默认：https://api.deepseek.com）
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 可选：使用的模型名称（默认：deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 可选：是否在严重问题时阻止提交（1 阻止 / 0 不阻止，默认：1）
# DEEPSEEK_BLOCK_ON_SEVERE=1

# 可选：自定义审查规则文件路径（默认：./rules.json）
# DEEPSEEK_RULES_PATH=./rules.json